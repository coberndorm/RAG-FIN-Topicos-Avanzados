# ============================================================
# FIN-Advisor RAG — Variables de Entorno
# ============================================================
# Copiar este archivo como .env y completar los valores:
#   cp .env.example .env
# ============================================================

# --- Proveedor de LLM ---
# Opciones: huggingface (por defecto), gemini (recomendado), chatgpt, groq
LLM_PROVIDER=huggingface

# --- Clave de API del proveedor de LLM ---
# Requerida para todos los proveedores:
#   - HuggingFace: obtener en https://huggingface.co/settings/tokens
#   - Gemini (gratis): obtener en https://makersuite.google.com
#   - ChatGPT: obtener en https://platform.openai.com/api-keys
#   - Groq (gratis): obtener en https://console.groq.com
LLM_API_KEY=

# --- Nombre del modelo de LLM ---
# Valores por defecto según proveedor:
#   - huggingface: meta-llama/Llama-3.1-70B-Instruct
#   - gemini: gemini-1.5-flash
#   - chatgpt: gpt-4o-mini
#   - groq: llama-3.3-70b-versatile
LLM_MODEL_NAME=

# --- Modelo de embeddings ---
# Modelo utilizado para generar embeddings en el ETL y la recuperación.
# Por defecto: intfloat/multilingual-e5-small (~134MB, optimizado para español)
# Alternativas: sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2,
#               intfloat/multilingual-e5-base
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-small

# --- Umbral de similitud para recuperación de conocimiento ---
# Puntuación mínima de similitud coseno para incluir fragmentos.
# Rango: 0.0 a 1.0 (valores más altos = resultados más relevantes)
SIMILARITY_THRESHOLD=0.35

# --- Directorio de persistencia de ChromaDB ---
# Ruta donde ChromaDB almacena los embeddings de la base de conocimiento.
CHROMA_PERSIST_DIR=./chroma_data

# --- Ruta de la base de datos SQLite ---
# Ruta al archivo de base de datos financiera (generado por generate_mock_data.py).
SQLITE_DB_PATH=./fin.db
